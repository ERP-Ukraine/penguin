<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="penguin_report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="class" add="mt-2 pt-2 w-50" remove="mt32" separator=" "/>
        </xpath>

        <xpath expr="//div[@name='invoice_date']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@name='due_date']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@name='origin']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@name='customer_code']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@name='reference']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]//th[@name='th_priceunit']" position="replace">
            <th name="th_list_price" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span>RRP/pc</span>
            </th>
            <th name="th_priceunit" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span>Net/pc</span>
            </th>
        </xpath>
        <xpath expr="//table[hasclass('o_main_table')]//span[@t-field='line.price_unit']/parent::td" position="replace">
            <td t-attf-class="text-end td_list_price {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span class="text-nowrap" t-esc="line.penguin_rrp_pc" t-options="{'widget': 'float', 'decimal_precision': 'Product Price'}"/>
            </td>
            <td t-attf-class="text-end td_priceunit {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span class="text-nowrap" t-esc="line.penguin_net_price_pc" t-options="{'widget': 'float', 'decimal_precision': 'Product Price'}"/>
            </td>
        </xpath>

        <xpath expr="//p[@name='payment_communication']" position="replace"/>
    </template>
</odoo>
