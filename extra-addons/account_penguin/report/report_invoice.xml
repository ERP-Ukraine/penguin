<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="penguin_report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="class" add="mt-4" remove="mt32" separator=" "/>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]//th[@name='th_priceunit']" position="replace">
            <th name="th_list_price" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>RRP/pc</span></th>
            <th name="th_priceunit" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Net Price/pc</span></th>
        </xpath>
        <xpath expr="//table[hasclass('o_main_table')]//span[@t-field='line.price_unit']/parent::td" position="replace">
            <td t-attf-class="text-right td_list_price {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span class="text-nowrap" t-esc="line.penguin_rrp_pc" t-options="{'widget': 'float', 'decimal_precision': 'Product Price'}"/>
            </td>
            <td t-attf-class="text-right td_priceunit {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span class="text-nowrap" t-esc="line.penguin_net_price_pc" t-options="{'widget': 'float', 'decimal_precision': 'Product Price'}"/>
            </td>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]//th[@name='th_subtotal']" position="replace">
            <th name="th_subtotal" class="text-right">
                <span groups="account.group_show_line_subtotals_tax_excluded">Total Net</span>
                <span groups="account.group_show_line_subtotals_tax_included">Total Net</span>
            </th>
        </xpath>
        <xpath expr="//table[hasclass('o_main_table')]//t[@t-set='current_subtotal'][@groups='account.group_show_line_subtotals_tax_included']" position="attributes">
            <!-- compute in the same way as `group_show_line_subtotals_tax_excluded` -->
            <attribute name="t-value">current_subtotal + line.price_subtotal</attribute>
        </xpath>
        <xpath expr="//table[hasclass('o_main_table')]//td[hasclass('o_price_total')]/span[@groups='account.group_show_line_subtotals_tax_included']" position="attributes">
            <!-- compute in the same way as `group_show_line_subtotals_tax_excluded` -->
            <attribute name="t-field">line.price_subtotal</attribute>
        </xpath>
    </template>
</odoo>
