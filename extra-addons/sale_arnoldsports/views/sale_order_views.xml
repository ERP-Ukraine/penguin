<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="view_order_form_inherit_sale_arnol" model="ir.ui.view">
        <field name="name">sale.order.form.sale.arnold</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//label[@for='commitment_date']" position="before">
                <field name="arnold_report_id" options="{'no_create': True}" />
            </xpath>
       </field>
    </record>

</odoo>
