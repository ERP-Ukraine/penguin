<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="sale_order_arnold_report_orders_tree" model="ir.ui.view">
        <field name="name">sale_order_arnold_report_orders.tree</field>
        <field name="model">sale.order.arnold.report</field>
        <field name="arch" type="xml">
            <tree string="Arnold Sports Reports to Process">
                <field name="name"/>
                <field name="order_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>
    <record id="sale_order_arnold_report_orders_form" model="ir.ui.view">
        <field name="name">sale_order_arnold_report_orders.form</field>
        <field name="model">sale.order.arnold.report</field>
        <field name="arch" type="xml">
            <form string="Arnold Sports Reports to Process">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="order_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sale_order_arnold_report_orders_action" model="ir.actions.act_window">
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
        <field name="context">{}</field>
        <field name="domain" eval="False"/>
        <field name="filter" eval="False"/>
        <field name="groups_id" eval="[(6, 0, [])]"/>
        <field name="limit">80</field>
        <field name="name">Arnold Sports Order Reports</field>
        <field name="res_model">sale.order.arnold.report</field>
        <field name="search_view_id" eval="False"/>
        <field name="target">current</field>
        <field name="type">ir.actions.act_window</field>
        <field name="usage" eval="False"/>
        <field name="view_id" eval="False"/>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="sale_order_arnold_report_orders_menu" model="ir.ui.menu">
        <field name="action" ref="sale_order_arnold_report_orders_action"/>
        <field name="active" eval="True"/>
        <field name="groups_id" eval="[(6, 0, [])]"/>
        <field name="name">Arnold Sports Order Reports</field>
        <field name="parent_id" ref="sale.menu_sale_config"/>
        <field name="sequence">5</field>
        <field name="web_icon" eval="False"/>
    </record>

</odoo>
