<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock.action_report_delivery" model="ir.actions.report">
        <field name="paperformat_id" ref="report_tmpl_penguin.paperformat_penguin"/>
    </record>

    <record id="stock.action_report_picking" model="ir.actions.report">
        <field name="paperformat_id" ref="report_tmpl_penguin.paperformat_penguin"/>
    </record>

    <template id="report_delivery_document" inherit_id="stock.report_delivery_document">
        <xpath expr="//t[@t-set='o']" position="after">
            <t t-set="warehouse" t-value="o.picking_type_id.warehouse_id"/>
        </xpath>

        <xpath expr="//p[@t-field='o.date_done']" position="attributes">
            <attribute name="t-options">{'widget': 'date'}</attribute>
        </xpath>

        <xpath expr="//p[@t-field='o.scheduled_date']" position="attributes">
            <attribute name="t-options">{'widget': 'date'}</attribute>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']//span[@t-field='move.product_uom_qty']" position="replace">
            <span t-if="move.product_uom_qty.is_integer()" t-esc="int(move.product_uom_qty)"/>
            <span t-else="" t-field="move.product_uom_qty" t-options="{'widget': 'float', 'decimal_precision': 'Quantity, Penguin Report Template'}"/>
        </xpath>
    </template>

    <template id="stock_report_delivery_has_serial_move_line" inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//span[@t-field='move_line.quantity']" position="replace">
            <span t-if="move_line.quantity.is_integer()" t-esc="int(move_line.quantity)"/>
            <span t-else="" t-field="move_line.quantity" t-options="{'widget': 'float', 'decimal_precision': 'Quantity, Penguin Report Template'}"/>
        </xpath>
    </template>

    <template id="stock_report_delivery_aggregated_move_lines" inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        <xpath expr="//td[@name='move_line_aggregated_quantity']/t/span[1]" position="replace">
            <span t-if="aggregated_lines[line]['quantity'].is_integer()" t-esc="int(aggregated_lines[line]['quantity'])"
                        t-options="{'widget': 'float', 'decimal_precision': 'Product Unit of Measure'}"/>
            <span t-else="" t-esc="aggregated_lines[line]['quantity']" t-options="{'widget': 'float', 'decimal_precision': 'Quantity, Penguin Report Template'}"/>
        </xpath>
    </template>

    <template id="report_picking" inherit_id="stock.report_picking">
        <xpath expr="//t[@t-call='web.external_layout']" position="before">
            <t t-set="warehouse" t-value="o.picking_type_id.warehouse_id"/>
        </xpath>

        <xpath expr="//p[@t-field='o.scheduled_date']" position="attributes">
            <attribute name="t-options">{'widget': 'date'}</attribute>
        </xpath>

        <xpath expr="//div[@name='div_outgoing_address']" position="attributes">
            <attribute name="class">col-4 offset-2</attribute>
        </xpath>

        <xpath expr="//div[@name='div_incoming_address']" position="attributes">
            <attribute name="class">col-4 offset-2</attribute>
        </xpath>

        <xpath expr="//span[@t-field='ml.quantity']" position="replace">
            <span t-if="ml.quantity.is_integer()" t-esc="int(ml.quantity)"/>
            <span t-else="" t-field="ml.quantity" t-options="{'widget': 'float', 'decimal_precision': 'Quantity, Penguin Report Template'}"/>
        </xpath>
    </template>

</odoo>
