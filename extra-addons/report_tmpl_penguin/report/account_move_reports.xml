<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account.account_invoices" model="ir.actions.report">
        <field name="paperformat_id" ref="report_tmpl_penguin.paperformat_penguin"/>
    </record>

    <record id="account.account_invoices_without_payment" model="ir.actions.report">
        <field name="paperformat_id" ref="report_tmpl_penguin.paperformat_penguin"/>
    </record>

    <template id="report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-set='o']" position="after">
            <t t-set="warehouse" t-value="o.mapped('invoice_line_ids.sale_line_ids.order_id.warehouse_id')[:1]"/>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]//span[@t-field='line.quantity']" position="replace">
            <span t-if="line.quantity.is_integer()" t-esc="int(line.quantity)"/>
            <span t-else="" t-field="line.quantity"/>
        </xpath>

        <xpath expr="//tr[hasclass('o_subtotal')]/td/strong" position="attributes">
            <attribute name="class" add="skip-text-bolder" separator=" "/>
        </xpath>
    </template>

</odoo>
