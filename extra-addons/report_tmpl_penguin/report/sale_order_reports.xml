<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="paperformat_id" ref="report_tmpl_penguin.paperformat_penguin"/>
    </record>

    <template id="report_saleorder_document" inherit_id="sale.report_saleorder_document">
        <xpath expr="//t[@t-set='doc']" position="after">
            <t t-set="warehouse" t-value="doc.warehouse_id"/>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]//span[@t-field='line.product_uom_qty']" position="replace">
            <span t-if="line.product_uom_qty.is_integer()" t-esc="int(line.product_uom_qty)"/>
            <span t-else="" t-field="line.product_uom_qty" t-options="{'widget': 'float', 'decimal_precision': 'Quantity, Penguin Report Template'}"/>
        </xpath>
    </template>

</odoo>
