<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="sale_order_portal_content" inherit_id="sale.sale_order_portal_content">
    <xpath expr="//table[@id='sales_order_table']/tbody//span[@t-field='line.product_uom_qty']" position="replace">
        <span t-if="line.product_uom_qty.is_integer()" t-esc="int(line.product_uom_qty)"/>
        <span t-else="" t-field="line.product_uom_qty" t-options="{'widget': 'float', 'decimal_precision': 'Quantity, Penguin Report Template'}"/>
    </xpath>
</template>

</odoo>
