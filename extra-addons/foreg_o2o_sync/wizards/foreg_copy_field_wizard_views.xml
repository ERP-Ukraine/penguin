<odoo>
    <!-- Wizard View -->
    <record id="foreg_copy_field_wizard_view_form" model="ir.ui.view">
        <field name="name">foreg.copy.field.wizard.view.form</field>
        <field name="model">foreg.copy.field.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="field_id" readonly="1" force_save="1" />
                        <field name="field_type" />
                        <field name="model_id" />
                        <field name="apply_model_ids" widget="many2many_tags" />
                    </group>
                </sheet>
                <footer>
                    <button
                        string="Apply"
                        type="object"
                        name="action_apply"
                        class="oe_highlight"
                    />
                    <button string="Cancel" class="btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_foreg_copy_field_wizard" model="ir.actions.act_window">
        <field name="name">Copy Field Wizard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">foreg.copy.field.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
