<odoo>
    <record id="foreg_o2o_request_log_view_tree" model="ir.ui.view">
        <field name="name">foreg.o2o.request.log.view.list</field>
        <field name="model">foreg.o2o.request.log</field>
        <field name="arch" type="xml">
            <list
                decoration-danger="state == 'fail'"
                decoration-success="state == 'pass'"
            >
                <field name="create_date" />
                <field name="request_id" optional="hide" />
                <field name="execution_time" />
                <field name="state" />
                <button
                    name="action_view_full"
                    type="object"
                    icon="fa-bars"
                    title="View Full"
                />
                <button
                    name="action_view_log"
                    type="object"
                    icon="fa-code"
                    title="View Log"
                />
            </list>
        </field>
    </record>
    <record id="foreg_o2o_request_log_view_form" model="ir.ui.view">
        <field name="name">foreg.o2o.request.log.view.form</field>
        <field name="model">foreg.o2o.request.log</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_view_log"
                        type="object"
                        string="View Log"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="request_id" />
                            <field name="execution_time" />
                            <field name="state" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Response">
                            <field name="response_json" invisible="1" />
                            <field
                                name="response"
                                widget="ace"
                                options="{'mode': 'python'}"
                            />
                        </page>
                        <page string="Request Params">
                            <field name="request_kwargs_json" invisible="1" />
                            <field
                                name="request_kwargs"
                                widget="ace"
                                options="{'mode': 'python'}"
                            />
                        </page>
                        <page string="Records">
                            <field name="record_ids">
                                <list>
                                    <field name="create_date" />
                                    <field name="method_applied" />
                                    <field name="res_ref" />
                                    <field name="res_model" invisible="0" />
                                    <field name="res_id" invisible="1" />
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="method_applied" />
                                                <field name="res_ref" />
                                                <field name="res_model" invisible="1" />
                                                <field name="res_id" invisible="1" />
                                                <field
                                                    name="process_values_json"
                                                    invisible="1"
                                                />
                                            </group>
                                            <separator string="Values" />
                                            <field
                                                name="process_values"
                                                widget="ace"
                                                options="{'mode': 'python'}"
                                            />
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="foreg_o2o_request_log_view_form_log_only" model="ir.ui.view">
        <field name="name">foreg.o2o.request.log.view.form.log.only</field>
        <field name="model">foreg.o2o.request.log</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="logs" />
                </sheet>
            </form>
        </field>
    </record>

    <record id="foreg_o2o_request_log_view_form_simple" model="ir.ui.view">
        <field name="name">foreg.o2o.request.log.view.form.simple</field>
        <field name="model">foreg.o2o.request.log</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_view_full"
                        type="object"
                        string="View Full"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="model" invisible="0" />
                            <field
                                name="read_filter"
                                widget="domain"
                                options="{'model': 'model'}"
                                invisible="not read_filter"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page string="Records">
                            <field name="record_ids" invisible="1" />
                            <field name="model_record_ids">
                                <list>
                                    <field name="create_date" />
                                    <field name="method_applied" />
                                    <field name="res_ref" />
                                    <field name="res_model" column_invisible="0" />
                                    <field name="res_id" column_invisible="1" />
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="method_applied" />
                                                <field name="res_ref" />
                                                <field name="res_model" invisible="1" />
                                                <field name="res_id" invisible="1" />
                                                <field
                                                    name="process_values_json"
                                                    invisible="1"
                                                />
                                            </group>
                                            <separator string="Values" />
                                            <field
                                                name="process_values"
                                                widget="ace"
                                                options="{'mode': 'python'}"
                                            />
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="foreg_o2o_request_log_view_search" model="ir.ui.view">
        <field name="name">foreg.o2o.request.log.view.search</field>
        <field name="model">foreg.o2o.request.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="request_id" />
                <field name="state" />
                <separator />
                <filter
                    name="filter_request_id"
                    string="Request"
                    context="{'group_by': 'request_id'}"
                />
                <separator />
                <filter
                    name="filter_state"
                    string="State"
                    context="{'group_by': 'state'}"
                />
                <separator />
                <filter name="filter_date" string="Date" date="create_date" />
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="foreg_o2o_request_log_action" model="ir.actions.act_window">
        <field name="name">4EG O2O Request Logs</field>
        <field name="res_model">foreg.o2o.request.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
