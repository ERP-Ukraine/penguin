<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.default.mailing.list</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mass_mailing.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='group_mass_mailing_campaign']/../../.." position="inside">
                <div class="col-md-6 o_setting_box col-xs-12">
                    <div class="o_setting_right_pane">
                        <label for="contacts_mass_mailing_list"/>
                        <div class="text-muted">
                            Choose which mailing list must be default for new contacts
                        </div>
                    </div>
                    <div class="o_setting_right_pane" title="Choose default mailing list to insert in new contacts.">
                        <field name="contacts_mass_mailing_list"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
