<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.default.mailing.list</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mass_mailing.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='managa_mail_campaigns_setting_container']" position="inside">
                <setting name="contacts_mass_mailing_list_setting_container" title="Choose default mailing list to insert in new contacts" help="Choose which mailing list must be default for new contacts">
                    <field name="contacts_mass_mailing_list"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
