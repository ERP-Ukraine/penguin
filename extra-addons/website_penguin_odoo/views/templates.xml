<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="penguin_product" inherit_id="website_sale.product">
        <xpath expr="//form[@t-if='product._is_add_to_cart_possible()']//p[hasclass('css_not_available_msg')]" position="replace">
            <p t-if="True" class="css_not_available_msg alert alert-warning">Your selected item is currently not in stock</p>
        </xpath>
    </template>
</odoo>
