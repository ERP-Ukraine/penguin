<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="registration_template" inherit_id="website_event.registration_template">
    <xpath expr="//button[@data-bs-target='#modal_ticket_registration']" position="replace">
        <button type="button" data-bs-toggle="modal" data-bs-target="#modal_ticket_registration" t-attf-class="d-none btn btn-primary {{cta_additional_classes}}">Register</button>
        <a t-if="event.event_registrations_open and event.url" t-attf-href="#{event.url}" class="oe_unremovable btn btn-primary btn_cta"><t t-out="event.url_label"/><t t-if="not event.url_label">S'inscrire</t></a>
    </xpath>
</template>
</odoo>
