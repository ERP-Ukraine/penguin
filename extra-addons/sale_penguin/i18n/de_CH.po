#. module: sale_penguin
#: model:mail.template,body_html:sale_penguin.mail_template_sale_confirmation
msgid ""
"<div style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\">\n"
"                    <t t-if=\"object.state == 'future_sale'\" data-oe-t-group-active=\"true\">\n"
"                        <p style=\"margin:0px;box-sizing:border-box;padding:0px;font-size: 12px;\">\n"
"                            Hi,<br>\n"
"                            Thank you for your pre-order. Please find enclosed our order entry confirmation.\n"
"                            <br>\n"
"                            We’ll get back to you begin of March with the final order confirmation.\n"
"                            <br><br>\n"
"                        </p>\n"
"                    </t>\n"
"                    <t t-elif=\"object.state == 'future_sale_confirmation'\">\n"
"                        <p style=\"margin:0px;box-sizing:border-box;padding:0px;font-size: 12px;\">\n"
"                            Hi,<br>\n"
"                            Please find enclosed our final order confirmation.\n"
"                            <br>\n"
"                            Delivery is scheduled for mid-October.\n"
"                            <br><br>\n"
"                        </p>\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                        <p style=\"margin:0px;box-sizing:border-box;padding:0px;font-size: 12px;\">\n"
"                            Dear <t t-out=\"object.partner_id.name\" data-oe-t-inline=\"true\"></t>,<br>\n"
"                            Thank you for your virtual visit.\n"
"                            <br><br>\n"
"                            <t t-set=\"transaction\" t-value=\"object.get_portal_last_transaction()\" data-oe-t-inline=\"true\"></t>\n"
"                            Your order\n"
"                            <strong style=\"box-sizing:border-box;font-weight:500;\"><t t-out=\"object.name\" data-oe-t-inline=\"true\"></t></strong> amounting in <strong style=\"box-sizing:border-box;font-weight:500;\"><t t-esc=\"format_amount(object.amount_total, object.currency_id)\" data-oe-t-inline=\"true\"></t></strong>\n"
"                            <t t-if=\"object.state == 'sale' or (transaction and transaction.state in ('done', 'authorized'))\" data-oe-t-group-active=\"true\">\n"
"                                has been confirmed.<br>\n"
"                                Thank you for your trust!\n"
"                            </t>\n"
"                            <t t-elif=\"transaction and transaction.state == 'pending'\">\n"
"                                is pending. It will be confirmed when the payment is received.\n"
"                                <t t-if=\"object.reference\" data-oe-t-group-active=\"true\">\n"
"                                    Your payment reference is <strong style=\"box-sizing:border-box;font-weight:500;\"><t t-out=\"object.reference\" data-oe-t-inline=\"true\"></t></strong>.\n"
"                                </t>\n"
"                            </t>\n"
"                            <br><br>\n"
"                            Do not hesitate to contact us if you have any questions.\n"
"                            <br><br>\n"
"                        </p>\n"
"                    </t>\n"
"                    <t t-if=\"hasattr(object, 'website_id') and object.website_id\" data-oe-t-group-active=\"true\">\n"
"                        <div style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\">\n"
"                            <table width=\"100%\" style=\"box-sizing:border-box;color: #454748; font-size: 12px; border-collapse: collapse;\">\n"
"                                <tbody><tr style=\"border-bottom: 2px solid #dee2e6;\">\n"
"                                    <td style=\"width: 150px;\"><strong style=\"box-sizing:border-box;font-weight:500;\">Products</strong></td>\n"
"                                    <td></td>\n"
"                                    <td width=\"15%\" align=\"center\"><strong style=\"box-sizing:border-box;font-weight:500;\">Quantity</strong></td>\n"
"                                    <td width=\"20%\" align=\"right\"><strong style=\"box-sizing:border-box;font-weight:500;\">\n"
"                                    <t t-if=\"object.user_id.has_group('account.group_show_line_subtotals_tax_excluded')\" data-oe-t-group-active=\"true\">\n"
"                                        VAT Excl.\n"
"                                    </t>\n"
"                                    <t t-else=\"\">\n"
"                                        VAT Incl.\n"
"                                    </t>\n"
"                                    </strong></td>\n"
"                                </tr>\n"
"                            </tbody></table>\n"
"                            <t t-foreach=\"object.order_line\" t-as=\"line\">\n"
"                                <t t-if=\"(not hasattr(line, 'is_delivery') or not line.is_delivery) and line.display_type in ['line_section', 'line_note']\" data-oe-t-group-active=\"true\">\n"
"                                    <t t-set=\"loop_cycle_number\" t-value=\"0\" data-oe-t-inline=\"true\"></t><t t-set=\"loop_cycle_number\" t-value=\"loop_cycle_number + 1\" data-oe-t-inline=\"true\"></t><table width=\"100%\" style=\"box-sizing:border-box;color: #454748; font-size: 12px; border-collapse: collapse;\">\n"
"                                        \n"
"                                        <tbody><tr t-att-style=\"'background-color: #f2f2f2' if loop_cycle_number % 2 == 0 else 'background-color: #ffffff'\">\n"
"                                            \n"
"                                            <td colspan=\"4\">\n"
"                                                <t t-if=\"line.display_type == 'line_section'\" data-oe-t-group-active=\"true\">\n"
"                                                    <strong t-out=\"line.name or ''\" style=\"box-sizing:border-box;font-weight:500;\">Taking care of Trees Course</strong>\n"
"                                                </t>\n"
"                                                <t t-elif=\"line.display_type == 'line_note'\">\n"
"                                                    <i t-out=\"line.name or ''\">Taking care of Trees Course</i>\n"
"                                                </t>\n"
"                                            </td>\n"
"                                        </tr>\n"
"                                    </tbody></table>\n"
"                                </t>\n"
"                                <t t-elif=\"(not hasattr(line, 'is_delivery') or not line.is_delivery)\">\n"
"                                    <t t-set=\"loop_cycle_number\" t-value=\"0\" data-oe-t-inline=\"true\"></t><t t-set=\"loop_cycle_number\" t-value=\"loop_cycle_number + 1\" data-oe-t-inline=\"true\"></t><table width=\"100%\" style=\"box-sizing:border-box;color: #454748; font-size: 12px; border-collapse: collapse;\">\n"
"                                        \n"
"                                        <tbody><tr t-att-style=\"'background-color: #f2f2f2' if loop_cycle_number % 2 == 0 else 'background-color: #ffffff'\">\n"
"                                            \n"
"                                            <td style=\"width: 150px;\">\n"
"                                                <img t-attf-src=\"/web/image/product.product/{{ line.product_id.id }}/image_128\" style=\"border-style:none;box-sizing:border-box;vertical-align:middle;width: 64px; height: 64px; object-fit: contain;\" alt=\"Product image\" width=\"64px\" height=\"64\">\n"
"                                            </td>\n"
"                                            <td align=\"left\" t-out=\"line.product_id.name or ''\">\tTaking care of Trees Course</td>\n"
"                                            <td width=\"15%\" align=\"center\" t-out=\"line.product_uom_qty or ''\">1</td>\n"
"                                            <td width=\"20%\" align=\"right\"><strong style=\"box-sizing:border-box;font-weight:500;\">\n"
"                                            <t t-if=\"object.user_id.has_group('account.group_show_line_subtotals_tax_excluded')\" data-oe-t-group-active=\"true\">\n"
"                                                <t t-out=\"format_amount(line.price_reduce_taxexcl, object.currency_id) or ''\" data-oe-t-inline=\"true\">$ 10.00</t>\n"
"                                            </t>\n"
"                                            <t t-else=\"\">\n"
"                                                <t t-out=\"format_amount(line.price_reduce_taxinc, object.currency_id) or ''\" data-oe-t-inline=\"true\">$ 10.00</t>\n"
"                                            </t>\n"
"                                            </strong></td>\n"
"                                        </tr>\n"
"                                    </tbody></table>\n"
"                                </t>\n"
"                            </t>\n"
"                        </div>\n"
"                        <div style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\" t-if=\"hasattr(object, 'carrier_id') and object.carrier_id and hasattr(object, 'amount_delivery')\" data-oe-t-group-active=\"true\">\n"
"                            <table width=\"100%\" style=\"box-sizing:border-box;-webkit-border-vertical-spacing:4px;-webkit-border-horizontal-spacing:0px;border-collapse:collapse;color: #454748; font-size: 12px; border-spacing: 0px 4px;\" align=\"right\">\n"
"                                <tbody><tr>\n"
"                                    <td style=\"width: 60%\"></td>\n"
"                                    <td style=\"width: 30%; border-top: 1px solid #dee2e6;\" align=\"right\"><strong style=\"box-sizing:border-box;font-weight:500;\">Delivery:</strong></td>\n"
"                                    <td style=\"width: 10%; border-top: 1px solid #dee2e6;\" align=\"right\" t-out=\"format_amount(object.amount_delivery, object.currency_id) or ''\"></td>\n"
"                                </tr>\n"
"                                <tr>\n"
"                                    <td style=\"width: 60%\"></td>\n"
"                                    <td style=\"width: 30%;\" align=\"right\"><strong style=\"box-sizing:border-box;font-weight:500;\">SubTotal:</strong></td>\n"
"                                    <td style=\"width: 10%;\" align=\"right\" t-out=\"format_amount(object.amount_untaxed, object.currency_id) or ''\"></td>\n"
"                                </tr>\n"
"                            </tbody></table>\n"
"                        </div>\n"
"                        <div style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\" t-else=\"\">\n"
"                            <table width=\"100%\" style=\"box-sizing:border-box;-webkit-border-vertical-spacing:4px;-webkit-border-horizontal-spacing:0px;border-collapse:collapse;color: #454748; font-size: 12px; border-spacing: 0px 4px;\" align=\"right\">\n"
"                                <tbody><tr>\n"
"                                    <td style=\"width: 60%\"></td>\n"
"                                    <td style=\"width: 30%; border-top: 1px solid #dee2e6;\" align=\"right\"><strong style=\"box-sizing:border-box;font-weight:500;\">SubTotal:</strong></td>\n"
"                                    <td style=\"width: 10%; border-top: 1px solid #dee2e6;\" align=\"right\" t-out=\"format_amount(object.amount_untaxed, object.currency_id) or ''\"></td>\n"
"                                </tr>\n"
"                            </tbody></table>\n"
"                        </div>\n"
"                        <div style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\">\n"
"                            <table width=\"100%\" style=\"box-sizing:border-box;-webkit-border-vertical-spacing:4px;-webkit-border-horizontal-spacing:0px;border-collapse:collapse;color: #454748; font-size: 12px; border-spacing: 0px 4px;\" align=\"right\">\n"
"                                <tbody>\n"
"                                    <tr>\n"
"                                        <td style=\"width: 60%\"></td>\n"
"                                        <td style=\"width: 30%;\" align=\"right\"><strong style=\"box-sizing:border-box;font-weight:500;\">Taxes:</strong></td>\n"
"                                        <td style=\"width: 10%;\" align=\"right\" t-out=\"format_amount(object.amount_tax, object.currency_id) or ''\"></td>\n"
"                                    </tr>\n"
"                                    <tr>\n"
"                                        <td style=\"width: 60%\"></td>\n"
"                                        <td style=\"width: 30%; border-top: 1px solid #dee2e6;\" align=\"right\"><strong style=\"box-sizing:border-box;font-weight:500;\">Total:</strong></td>\n"
"                                        <td style=\"width: 10%; border-top: 1px solid #dee2e6;\" align=\"right\" t-out=\"format_amount(object.amount_total, object.currency_id) or ''\"></td>\n"
"                                    </tr>\n"
"                                </tbody>\n"
"                            </table>\n"
"                        </div>\n"
"                        <div t-if=\"object.partner_invoice_id\" style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\" data-oe-t-group-active=\"true\">\n"
"                            <table width=\"100%\" style=\"box-sizing:border-box;border-collapse:collapse;color: #454748; font-size: 12px;\">\n"
"                                <tbody>\n"
"                                    <tr>\n"
"                                        <td style=\"padding-top:10px;\">\n"
"                                            <strong style=\"box-sizing:border-box;font-weight:500;\">Bill to:</strong>\n"
"                                            <t t-out=\"object.partner_invoice_id.street or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_invoice_id.city or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_invoice_id.state_id.name or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_invoice_id.zip or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_invoice_id.country_id.name or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                    <tr>\n"
"                                        <td>\n"
"                                            <strong style=\"box-sizing:border-box;font-weight:500;\">Payment Method:</strong>\n"
"                                            <t t-if=\"transaction.token_id\" data-oe-t-group-active=\"true\">\n"
"                                                <t t-out=\"transaction.token_id.name or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            </t>\n"
"                                            <t t-else=\"\">\n"
"                                                <t t-out=\"transaction.acquirer_id.sudo().name or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            </t>\n"
"                                            (<t t-out=\"format_amount(transaction.amount, object.currency_id) or ''\" data-oe-t-inline=\"true\"></t>)\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </tbody>\n"
"                            </table>\n"
"                        </div>\n"
"                        <div t-if=\"object.partner_shipping_id and not object.only_services\" style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\" data-oe-t-group-active=\"true\">\n"
"                            <table width=\"100%\" style=\"box-sizing:border-box;border-collapse:collapse;color: #454748; font-size: 12px;\">\n"
"                                <tbody>\n"
"                                    <tr>\n"
"                                        <td>\n"
"                                            <br>\n"
"                                            <strong style=\"box-sizing:border-box;font-weight:500;\">Ship to:</strong>\n"
"                                            <t t-out=\"object.partner_shipping_id.street or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_shipping_id.city or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_shipping_id.state_id.name or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_shipping_id.zip or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-out=\"object.partner_shipping_id.country_id.name or ''\" data-oe-t-inline=\"true\"></t>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </tbody>\n"
"                            </table>\n"
"                            <table t-if=\"hasattr(object, 'carrier_id') and object.carrier_id\" width=\"100%\" style=\"box-sizing:border-box;border-collapse:collapse;color: #454748; font-size: 12px;\" data-oe-t-group-active=\"true\">\n"
"                                <tbody>\n"
"                                    <tr>\n"
"                                        <td>\n"
"                                            <strong style=\"box-sizing:border-box;font-weight:500;\">Shipping Method:</strong>\n"
"                                            <t t-out=\"object.carrier_id.name\" data-oe-t-inline=\"true\"></t>\n"
"                                            <t t-if=\"object.carrier_id.fixed_price == 0.0\" data-oe-t-group-active=\"true\">\n"
"                                                (Free)\n"
"                                            </t>\n"
"                                            <t t-else=\"\">\n"
"                                                (<t t-out=\"format_amount(object.carrier_id.fixed_price, object.currency_id) or ''\" data-oe-t-inline=\"true\"></t>)\n"
"                                            </t>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </tbody>\n"
"                            </table>\n"
"                        </div>\n"
"                    </t>\n"
"                    Best regards,<br>\n"
"                    Team Penguin\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"box-sizing:border-box;font-size:13px;margin: 0px; padding: 0px;\">\n"
