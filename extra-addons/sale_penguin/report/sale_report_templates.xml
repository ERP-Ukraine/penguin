<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_saleorder_document" inherit_id="sale.report_saleorder_document">

        <xpath expr="//div[hasclass('page')]/h2" position="replace">
            <h2 class="mt16">
                <t t-if="env.context.get('proforma', False) or is_pro_forma">
                    <span>Pro-Forma Invoice # </span>
                </t>
                <t t-elif="doc.state in ['draft','sent']">
                    <span>Quotation # </span>
                </t>
                <t t-elif="doc.state == 'future_sale'">
                    <span>Acknowledgement of order # </span>
                </t>
                <t t-elif="doc.state == 'future_sale_confirmation'">
                    <span>Final order confirmation # </span>
                </t>
                <t t-else="">
                    <span>Order confirmation # </span>
                </t>
                <span t-field="doc.name"/>
            </h2>
        </xpath>

        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="class" add="mt-4" remove="mt32" separator=" "/>
        </xpath>

        <xpath expr="//div[@t-if='doc.client_order_ref']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//p[@t-field='doc.date_order'][1]/parent::div" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//p[@t-field='doc.date_order'][@t-options='{&quot;widget&quot;: &quot;date&quot;}']/parent::div" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@name='expiration_date']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@t-if='doc.user_id.name']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@id='informations']" position="inside">
            <div t-if="doc.pricelist_id" class="col-2 w-100 mb-2">
                <strong>Pricelist:</strong>
                <p class="m-0" t-field="doc.pricelist_id"/>
            </div>

            <div t-if="doc.commitment_date" class="col-2 w-100 mb-2">
                <strong>Planned Delivery Date:</strong>
                <p class="m-0" t-field="doc.commitment_date" t-options="{'widget': 'date'}"/>
            </div>
        </xpath>

        <!-- PEN-64 Show discount % on PDF -->
        <!-- <xpath expr="//th[@name='th_discount']" position="replace">
        </xpath>
        <xpath expr="//td[@t-if='display_discount']" position="replace">
        </xpath> -->

        <xpath expr="//table[hasclass('o_main_table')]//th[@name='th_priceunit']" position="replace">
            <th name="th_list_price" class="text-right">RRP/pc</th>
            <th name="th_priceunit" class="text-right">Net Price/pc</th>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]//th[@name='th_subtotal']" position="replace">
            <th name="th_subtotal" class="text-right">
                <t groups="account.group_show_line_subtotals_tax_excluded">Total Net</t>
                <t groups="account.group_show_line_subtotals_tax_included">Total Net</t>
            </th>
        </xpath>

        <!-- <xpath expr="//td[@name='td_amount_by_group_label_3']" position="replace">
            <td name="td_amount_by_group_label_3">
                <span t-esc="amount_by_group[0]"/>
            </td>
        </xpath> -->

        <xpath expr="//table[hasclass('o_main_table')]//td[@name='td_priceunit']" position="replace">
            <td name="td_list_price" class="text-right">
                <span t-esc="line.penguin_rrp_pc" t-options="{'widget': 'float', 'decimal_precision': 'Product Price'}"/>
            </td>
            <td name="td_priceunit" class="text-right">
                <span t-esc="line.penguin_net_price_pc" t-options="{'widget': 'float', 'decimal_precision': 'Product Price'}"/>
            </td>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]//t[@t-set='current_subtotal'][@groups='account.group_show_line_subtotals_tax_included']" position="attributes">
            <!-- compute in the same way as `group_show_line_subtotals_tax_excluded` -->
            <attribute name="t-value">current_subtotal + line.price_subtotal</attribute>
        </xpath>
        <xpath expr="//table[hasclass('o_main_table')]//td[@name='td_subtotal']/span[@groups='account.group_show_line_subtotals_tax_included']" position="attributes">
            <!-- compute in the same way as `group_show_line_subtotals_tax_excluded` -->
            <attribute name="t-field">line.price_subtotal</attribute>
        </xpath>
    </template>

    <!-- Customize Sale Reports View PEN-55 -->
    <record id="sale_enterprise.sale_report_action_dashboard" model="ir.actions.act_window">
        <field name="view_mode">pivot,graph,dashboard</field>
        <field name="context" eval="{'search_default_Quotations': 1, 'search_default_Sales': 1, 'time_ranges': {'field':'date_order', 'range':'this_year', 'comparisonRange':'previous_period'}}"/>
    </record>
    <record id="sale.action_order_report_all" model="ir.actions.act_window">
        <field name="context" eval="{'search_default_Sales': 1, 'time_ranges': {'field':'date_order', 'range':'this_year', 'comparisonRange':'previous_period'}}"/>
    </record>
    <record id="sale_enterprise.sale_report_action_dashboard_dashboard" model="ir.actions.act_window.view">
        <field name="sequence" eval="10"/>
    </record>

    <record id="sale_enterprise.sale_report_view_pivot" model="ir.ui.view">
        <field name="arch" type="xml">
            <pivot string="Sales Analysis" disable_linking="True" display_quantity="true">
                <field name="industry_id" type="row"/>
                <field name="state" type="row"/>
                <field name="product_uom_qty" type="measure"/>
                <field name="price_subtotal" type="measure"/>
                <field name="untaxed_amount_invoiced" type="measure"/>
                <field name="untaxed_amount_to_invoice" type="measure"/>
            </pivot>
        </field>
    </record>

</odoo>
