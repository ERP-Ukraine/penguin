<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="view_partner_form_salesperson_penguin" model="ir.ui.view">
        <field name="name">res.partner.penguin.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="///group[@name='sale']/field[@name='user_id']" position="attributes">
                <attribute name="domain">[('is_salesperson', '=', True)]</attribute>
            </xpath>
        </field>
    </record>

</odoo>
