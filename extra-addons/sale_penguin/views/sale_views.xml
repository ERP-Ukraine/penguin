<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_order_penguin_form" model="ir.ui.view">
        <field name="name">sale.order.penguin.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_confirm'][last()]" position="after">
                <button name="%(sale.action_view_sale_advance_payment_inv)d" string="Create Invoice"
                        type="action" context="{'default_advance_payment_method': 'percentage'}"
                        attrs="{'invisible': ['|',('invoice_status', '!=', 'no'), ('state', '!=', 'future_sale')]}"/>
                <button name="action_send_preorder_confirmation_email" string="Pre-order Email" type="object"
                        attrs="{'invisible': [('state', 'not in', ['future_sale'])]}"/>
                <button name="action_send_preorder_confirmation_email" string="Final Pre-order Email" type="object"
                        attrs="{'invisible': [('state', 'not in', ['future_sale_confirmation'])]}"/>
                <button name="action_preorder" string="Pre-order" type="object"
                        attrs="{'invisible': [('state', 'not in', ['draft'])]}"/>
                <button name="action_preorder_confirmation" string="Pre-order Confirmation" type="object"
                        attrs="{'invisible': [('state', 'not in', ['future_sale'])]}"/>
            </xpath>
            <xpath expr="//button[@name='action_confirm'][1]" position="attributes">
                <attribute name="attrs">{'invisible': [('state', 'not in', ['sent', 'future_sale_confirmation'])]}</attribute>
            </xpath>
            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="states" add="future_sale,future_sale_confirmation" separator=","/>
            </xpath>
            <xpath expr="//tree/field[@name='price_unit']" position="before">
                <field name="penguin_rrp_pc"/>
            </xpath>
            <xpath expr="//page[@name='other_information']//field[@name='user_id']" position="attributes">
                <attribute name="domain">[('is_salesperson', '=', True)]</attribute>
            </xpath>
            <xpath expr="//field[@name='date_order']" position="attributes">
                <attribute name="groups"></attribute>
                <attribute name="nolabel"></attribute>
            </xpath>
        </field>
    </record>
</odoo>
