<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_purchaseorder_document" inherit_id="purchase.report_purchaseorder_document">

        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="class" add="mt-4" remove="mt32" separator=" "/>
        </xpath>

        <xpath expr="//div[@t-if='o.user_id']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@t-if='o.partner_ref']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

        <xpath expr="//div[@t-if='o.date_order']" position="attributes">
            <attribute name="class" add="col-2 w-100" remove="col-auto col-3 mw-100" separator=" "/>
        </xpath>

    </template>
</odoo>
