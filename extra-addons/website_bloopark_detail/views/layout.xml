                                            <td class="text-center"><span>180&#8211;188</span></td>
                                        </tr>
                                        <tr id="size-chart">
                                            <td><span>XL</span></td>
                                            <td class="text-center"><span>110</span></td>
                                            <td class="text-center"><span>114</span></td>
                                            <td class="text-center"><span>84</span></td>
                                            <td class="text-center"><span>185&#8211;193</span></td>
