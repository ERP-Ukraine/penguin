<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_product_same_images_view_form" model="ir.ui.view">
        <field name="name">product.product.same.images.view.form</field>
        <field name="model">product.product.same.images</field>
        <field name="arch" type="xml">
            <form string="Product">
                <sheet>
                    <group name="base">
                        <field name='product_id' invisible="1"/>
                        <field name='attribute_id' options="{'no_create_edit': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button type="object" name="run" string="Run" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
