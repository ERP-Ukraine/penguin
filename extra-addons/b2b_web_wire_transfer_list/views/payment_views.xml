<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">Wire Transfer Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <field name="available_country_ids" position="after">
                <field name="use_b2b_limitation" />
                <field name="b2b_payment_partners" widget="many2many_tags" invisible="use_b2b_limitation == False" />
            </field>
        </field>
    </record>

</odoo>
