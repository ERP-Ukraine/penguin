<odoo>

    <!-- Add chatter to O2O Instance form view -->
    <record id="foreg_o2o_instance_form_chatter" model="ir.ui.view">
        <field name="name">foreg.o2o.instance.form.chatter</field>
        <field name="model">foreg.o2o.instance</field>
        <field name="inherit_id" ref="foreg_o2o_sync.foreg_o2o_instance_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="after">
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </xpath>
        </field>
    </record>

</odoo>
