<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="_assets_frontend_helpers" inherit_id="web._assets_frontend_helpers">
        <xpath expr="//link[1]" position="before">
            <link rel="stylesheet" type="text/scss" href="/website_penguin/static/src/scss/bootstrap_variables.scss"/>
        </xpath>
    </template>

    <template id="assets_frontend" inherit_id="website.assets_frontend">
        <xpath expr="link[last()]" position="after">
            <link rel="stylesheet" type="text/scss" href="/website_penguin/static/src/scss/website.scss"/>
        </xpath>
    </template>
</odoo>