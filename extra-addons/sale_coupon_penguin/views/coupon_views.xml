<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="coupon_view_form" model="ir.ui.view">
        <field name="name">coupon.coupon.form.penguin</field>
        <field name="model">coupon.coupon</field>
        <field name="inherit_id" ref="coupon.coupon_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sales_order_id']" position="after">
                <field name="discount_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
