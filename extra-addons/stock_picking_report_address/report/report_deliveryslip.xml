<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<data>

    <template id="report_delivery_document" inherit_id="stock.report_delivery_document">
        <xpath expr="//div[@name='div_outgoing_address']//div[2]" position="after">
            <div t-elif="o.picking_type_id.code == 'internal' and o.picking_type_id.warehouse_id.partner_id">
                <div t-field="o.picking_type_id.warehouse_id.partner_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>
            </div>
        </xpath>
    </template>

</data>
</odoo>
