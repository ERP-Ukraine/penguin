<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="penguin_report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//div[hasclass('invoice_main')]" position="after">
            <div class="mb-4" t-if="o.website_comment">
                <div class="mt-16">
                    <strong>Comment: </strong>
                    <span t-out="o.website_comment"/>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
