<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Comment -->
    <template id='comment_form' name='Comment form'  active="True">
        <form t-attf-action="/shop/comment#{redirect and '?r=' + redirect or ''}" method="post" name="website_comment">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" t-nocache="The csrf token must always be up to date."/>
            <div class="input-group w-100 my-2">
                <input name="comment" class="form-control" type="text" placeholder="Add your comment here..." t-att-value="website_sale_order.website_comment or None"/>
                <a href="#" role="button" class="btn btn-secondary a-submit ps-2">Apply</a>
            </div>
        </form>
    </template>

    <template id="website_comment_template" inherit_id="website_sale.total" name="Comment" active="False">
        <xpath expr="//div[@id='cart_total']//table/tr[last()]" position="after">
            <tr t-if="not hide_comment">
                <td colspan="3" class="text-end text-xl-end border-0 p-0">
                    <span>
                        <t t-set='website_comment' t-value="website_sale_order.website_comment"/>
                        <div t-if="not force_coupon" class="coupon_form">
                            <t t-call="website_sale_penguin.comment_form"/>
                        </div>
                    </span>
                </td>
            </tr>
        </xpath>
    </template>

    <template id="confirmation_with_comment" inherit_id="website_sale.confirmation" active="False">
        <xpath expr="//t[@t-set='hide_promotions']" position="after">
            <t t-set="hide_comment" t-value="True"/>
        </xpath>
    </template>

</odoo>
