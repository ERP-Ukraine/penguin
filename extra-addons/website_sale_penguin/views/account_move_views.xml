<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_website_comment_penguin" model="ir.ui.view">
        <field name="name">account.move.form.website.comment.penguin</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date_due']/.." position="after">
                <label for="website_comment"/>
                <div>
                    <field name="website_comment" string="Comment"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
