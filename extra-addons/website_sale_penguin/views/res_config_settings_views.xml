<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="res_config_settings_view_form" model="ir.ui.view">
    <field name="name">res.config.settings.view.penguin</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="website_sale.res_config_settings_view_form"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@id='website_settings']" position="inside">
            <div class="col-12 col-lg-6 o_setting_box" id="address_country_group_ids">
                <div class="o_setting_right_pane">
                    <label for="address_country_group_ids"/>
                    <span class="fa fa-lg fa-globe" title="Values set here are website-specific." groups="website.group_multi_website"/>
                    <div class="text-muted">
                        Select country groups which contain countries to display on website checkout address form
                    </div>
                    <div class="mt8">
                        <field name="address_country_group_ids" widget="many2many_tags"/>
                    </div>
                </div>
            </div>
        </xpath>
    </field>
</record>

</odoo>
