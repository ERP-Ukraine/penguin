<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="website_sale_stock_penguin.product_availability" t-inherit="website_sale_stock.product_availability" t-inherit-mode="extension">
        <xpath expr="//div[@id='stock_notification_div']//div[hasclass('btn-link')]" position="replace">
            <div class="btn btn-link px-0" t-if="!has_stock_notification"
                id="product_stock_notification_message">
                <i class="fa fa-envelope-o me-1"/>
                Notify me when back in stock
            </div>
        </xpath>
    </t>
</templates>
