<odoo>
    <!-- Form View -->
    <record id="foreg_data_import_export_view_form_inherit" model="ir.ui.view">
        <field name="name">foreg.data.import.export.view.form.inherit</field>
        <field name="model">foreg.data.import.export</field>
        <field
            name="inherit_id"
            ref="foreg_data_import_export.foreg_data_import_export_view_form"
        />
        <field name="arch" type="xml">
            <field name="model" position="after">
                <field name="o2o_instance_id" />
            </field>
        </field>
    </record>

    <!-- Menu (hidden as per requirements, but defined for reference) -->
    <menuitem
        id="foreg_data_import_export_menu"
        name="Import/Export Data"
        action="foreg_data_import_export.foreg_data_import_export_action"
        parent="foreg_o2o_sync.foreg_o2o_menu_root"
        groups="base.group_system"
        sequence="10"
    />
</odoo>
