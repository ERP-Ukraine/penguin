<?xml version="1.0" encoding="utf-8"?>

<odoo>

	<data noupdate="0">
		<!-- Odoo User Setting Access Rights -->
		<record model="ir.module.category"
			id="module_google_shopping_feed_gcs">
			<field name="name">Google Shopping</field>
			<field name="description">Google Shopping User Access Rights</field>
			<field name="sequence">100</field>
		</record>

		<record model="res.groups" id="group_google_shopping_feed_user">
			<field name="name">User</field>
			<field name="implied_ids"
				eval="[(4,ref('sales_team.group_sale_salesman_all_leads')),(4,ref('stock.group_tracking_lot')),(4,ref('account.group_account_manager'))]" />
			<field name="category_id" ref="module_google_shopping_feed_gcs" />
			<field name="users"
				eval="[(4, ref('base.user_root')),(4, ref('base.user_admin'))]" />
		</record>

		<record model="res.groups"
			id="group_google_shopping_feed_manager">
			<field name="name">Manager</field>
			<field name="category_id" ref="module_google_shopping_feed_gcs" />
			<field name="implied_ids"
				eval="[(4,ref('google_shopping_feed_gcs.group_google_shopping_feed_user')),(4,ref('stock.group_stock_manager')),(4,ref('sales_team.group_sale_manager')),(4,ref('account.group_account_manager')),(4,ref('base.group_erp_manager'))]" />
			<field name="users"
				eval="[(4, ref('base.user_root')),(4, ref('base.user_admin'))]" />
		</record>
	</data>

	<data noupdate="1">
		<!-- Update Manager Rights to Give Google Shopping Feed App Rights -->
		<record id="base.default_user" model="res.users">
			<field name="groups_id"
				eval="[(4,ref('google_shopping_feed_gcs.group_google_shopping_feed_manager'))]" />
		</record>

		<!-- Multi Company Rules for GS -->
		<record model="ir.rule"
			id="google_shopping_account_company_rule">
			<field name="name">Google Shopping Feed Account Mutli Company Rule
			</field>
			<field name="model_id" ref="model_google_shopping_feed_account" />
			<field name="global" eval="True" />
			<field name="domain_force">['|',('gs_company_id','=',False),('gs_company_id', 'in',
				company_ids)]</field>
		</record>

		<record model="ir.rule"
			id="google_shopping_instance_company_rule">
			<field name="name">Google Shopping Instance Mutli Company Rule</field>
			<field name="model_id" ref="model_google_shopping_feed_instance" />
			<field name="global" eval="True" />
			<field name="domain_force">['|',('gs_account_id.gs_company_id','=',False),('gs_account_id.gs_company_id',
				'in', company_ids)]
			</field>
		</record>

	</data>
</odoo>
