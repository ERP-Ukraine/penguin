<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
		<!-- Log Sequence Section -->
		<record id="google_shopping_feed_log_tracker_seq" model="ir.sequence">
			<field name="name">Google Shopping Feed Log Tracker Sequence</field>
			<field name="code">google.shopping.feed.log.tracker</field>
			<field name="padding">4</field>
			<field name="prefix">GSF/LOG/</field>
			<field name="company_id" eval="False" />
		</record>
		
		<record id="google_shopping_update_product_queue_data_seq" model="ir.sequence">
            <field name="name">Google Shopping Update Product Queue Data Sequence</field>
            <field name="code">google.shopping.update.product.queue.data</field>
            <field name="padding">4</field>
            <field name="prefix">UPDQ</field>
            <field name="company_id" eval="False" />
        </record>
        
        <record id="google_shopping_update_product_inventory_info_queue_seq" model="ir.sequence">
            <field name="name">Google Shopping Update Product Inventory Info. Queue Sequence</field>
            <field name="code">google.shopping.update.product.inventory.info.queue</field>
            <field name="padding">4</field>
            <field name="prefix">UPIIDQ</field>
            <field name="company_id" eval="False" />
        </record>
        
        <record id="google_shopping_get_product_status_queue_seq" model="ir.sequence">
            <field name="name">Google Shopping Get Product Status Queue Sequence</field>
            <field name="code">google.shopping.get.product.status.queue</field>
            <field name="padding">4</field>
            <field name="prefix">GPSQ</field>
            <field name="company_id" eval="False" />
        </record>
        
        <record id="google_shopping_import_product_info_queue_seq" model="ir.sequence">
            <field name="name">Google Shopping Import Product Info Queue Sequence</field>
            <field name="code">google.shopping.import.product.info.queue</field>
            <field name="padding">4</field>
            <field name="prefix">GPSQ</field>
            <field name="company_id" eval="False" />
        </record>
	</data>
</odoo>