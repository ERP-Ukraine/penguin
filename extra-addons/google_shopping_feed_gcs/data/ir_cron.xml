<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data noupdate="1">
        <record id="ir_cron_auto_update_products_in_gsf" model="ir.cron">
            <field name="name">Auto Update Products in Google Shopping(Do Not Delete)</field>
            <field name="active" eval="False"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="model_id" eval="ref('google_shopping_feed_gcs.model_google_shopping_feed_account')" />
            <field name="state">code</field>
            <field name="code">model.auto_update_products_in_gsf_cron(args={})</field>
        </record>
