<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>

		<!-- Product Brand -->
		<!-- Tree View Section -->
		<record id="product_brand_gsf_tree_view" model="ir.ui.view">
			<field name="name">product.brand.gsf.tree</field>
			<field name="model">product.brand.gsf</field>
			<field name="arch" type="xml">
				<tree>
					<field name="name" />
				</tree>
			</field>
		</record>

		<!-- Form View Section -->
		<record id="product_brand_gsf_from_view" model="ir.ui.view">
			<field name="name">product.brand.gsf.form</field>
			<field name="model">product.brand.gsf</field>
			<field name="arch" type="xml">
				<form>
					<sheet>
						<field name="name" class="text-truncate"
							placeholder="Product brand name..." />
					</sheet>
				</form>
			</field>
		</record>

		<!-- Action View Section -->
		<record id="product_brand_gsf_action"
			model="ir.actions.act_window">
			<field name="name">Product Brands</field>
			<field name="res_model">product.brand.gsf</field>
			<field name="view_id" ref="product_brand_gsf_tree_view" />
		</record>


		<!-- Product Brand Menu Section -->
		<menuitem id="product_brand_gsf_menu" name="Product Brands"
			parent="sale.menu_sale_config" action="product_brand_gsf_action" />


		<!-- Product Template -->
		<record id="product_tmpl_inherited_from_view"
			model="ir.ui.view">
			<field name="name">product.template.inherited.form</field>
			<field name="model">product.template</field>
			<field name="inherit_id"
				ref="product.product_template_only_form_view" />
			<field name="arch" type="xml">
				<field name="barcode" position="after">
					<field name="product_brand_id" />
				</field>
			</field>
		</record>
		
		<!-- Product Variant Form View -->
		<record id="gsf_inherited_product_normal_form_view"
            model="ir.ui.view">
            <field name="name">gsf.inherited.product.normal.form</field>
            <field name="model">product.product</field>
            <field name="inherit_id"
                ref="product.product_normal_form_view" />
            <field name="arch" type="xml">
                <field name="categ_id" position="after">
                    <field name="gs_image_url_gcs" invisible="1"/>
                </field>
            </field>
        </record>
	</data>
</odoo>
