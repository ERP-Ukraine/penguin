<?xml version="1.0" encoding="UTF-8"?>

<odoo>
	<data>

		<!-- Tree View Section -->
		<record id="product_brand_gsf_tree_view" model="ir.ui.view">
			<field name="name">product.brand.gsf.tree</field>
			<field name="model">product.brand.gsf</field>
			<field name="arch" type="xml">
				<tree>
					<field name="name" />
				</tree>
			</field>
		</record>

		<!-- Form View Section -->
		<record id="product_brand_gsf_form_view" model="ir.ui.view">
			<field name="name">product.brand.gsf.form</field>
			<field name="model">product.brand.gsf</field>
			<field name="arch" type="xml">
				<form>
					<sheet>
						<group>
							<group>
								<field name="name" class="text-truncate"
									placeholder="Product brand name..." />
							</group>
							<group>
							</group>
						</group>
					</sheet>
				</form>
			</field>
		</record>

		<!-- Action View Section -->
		<record id="product_brand_gsf_action"
			model="ir.actions.act_window">
			<field name="name">Google Shopping Product Brands</field>
			<field name="res_model">product.brand.gsf</field>
			<field name="view_mode">tree,form</field>
			<field name="view_id" ref="product_brand_gsf_tree_view" />
			<field name="help" type="html">
				<div>
					<br />
					<p>
						<b>There is no any Google Shopping Product Brands created yet.
						</b>
					</p>

				</div>
			</field>
		</record>

		<!-- Sub Menu Section -->
		<menuitem id="product_brand_gsf_menu" name="Product Brands"
			parent="google_shopping_feed_gcs.google_shopping_product_menu"
			sequence="1" action="product_brand_gsf_action" />

	</data>
</odoo>
