<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		<!-- Search View Section -->
		<record id="google_shopping_feed_account_search_view"
			model="ir.ui.view">
			<field name="name">google.shopping.feed.account.search</field>
			<field name="model">google.shopping.feed.account</field>
			<field name="arch" type="xml">
				<search>
					<field name="name" />
					<field name="gs_merchant_id" />

					<group expand="0" string="Group By...">
						<filter name="name" string="Shopping Account"
							icon="terp-personal" context="{'group_by':'name'}" />
					</group>
				</search>
			</field>
		</record>

		<!-- Tree View Section -->
		<record id="google_shopping_feed_account_tree_view"
			model="ir.ui.view">
			<field name="name">google.shopping.feed.tree</field>
			<field name="model">google.shopping.feed.account</field>
			<field name="arch" type="xml">
				<tree>
					<field name="name" />
					<field name="gs_company_id" />
					<field name="gs_merchant_id" />
					<field name="warehouse_ids" widget="many2many_tags" optional="hide" />
					<field name="state" decoration-success="state == 'confirmed'"
						decoration-info="state == 'authorized'" widget="badge"
						optional="show" />
				</tree>
			</field>
		</record>

		<!-- Form View Section -->
		<record id="google_shopping_feed_account_form_view"
			model="ir.ui.view">
			<field name="name">google.shopping.feed.account.form</field>
			<field name="model">google.shopping.feed.account</field>
			<field name="arch" type="xml">
				<form>
					<header>
						<button class="btn-primary" name="authorize_gsf_account"
							type="object" string="Authorize Shopping Account"
							attrs="{'invisible': [('state', '!=', 'new')]}" />
						<button class="btn-primary" name="get_gsf_tokens"
							string="Get Auth Token" type="object"
							attrs="{'invisible': [('state', '!=', 'authorized')]}" />
						<button name="reset_to_new" string="Reset To New"
							type="object" attrs="{'invisible': [('state', '=', 'new')]}" />
						<button class="btn-primary" name="get_gsf_refresh_tokens"
							string="Re-Generate Auth Token" type="object"
							attrs="{'invisible': [('state', '!=', 'confirmed')]}" />
						<button name="reset_to_authorized"
							string="Reset to Authorized" type="object"
							attrs="{'invisible': [('state', '!=', 'confirmed')]}" />

						<field name="state" widget="statusbar" />
					</header>
					<sheet>
						<div class="oe_button_box" name="button_box">
							<button name="action_view_shopping_instances" style="width:16%"
								type="object" class="oe_stat_button" icon="fa-pencil-square-o"
								attrs="{'invisible': [('gs_instances_count', '=', 0)]}">
								<field name="gs_instances_count" widget="statinfo"
									string="Shopping Instances" />
							</button>
							<button class="oe_stat_button"
								name="action_view_shopping_account_crons" type="object"
								icon="fa-cogs fa-spin" 
								attrs="{'invisible': [('gsf_account_cron_count', '=',0)]}"
								style="width:15%" groups="base.group_system">
								<field string="Active Schedulers"
									name="gsf_account_cron_count" widget="statinfo" />
							</button>
							<button class="oe_stat_button"
								name="action_open_gsf_crons_setting_view" type="object"
								icon="fa-wrench fa-spin" 
								style="width:16%" groups="base.group_system">
								Schedulers Setting
							</button>
						</div>
						<field name="image_1920" widget="image" class="oe_avatar"
							options="{&quot;preview_image&quot;: &quot;image_128&quot;}" />
						<div class="oe_title">
							<label class="oe_edit_only" for="name"
								string="Shopping Account Name" />
							<h1 class="d-flex flex-row justify-content-between">
								<field name="name" default_focus="1" class="text-truncate"
									placeholder="Enter shopping account name..." 
									attrs="{'readonly': [('state', '!=', 'new')]}" />
							</h1>
						</div>

						<notebook>
							<page string="General Informations">
								<group>
									<group>
										<field name="gs_company_id" required="1"
											attrs="{'readonly': [('state', '!=', 'new')]}"
											options="{'no_create': True, 'no_create_edit': True , 'no_open': True}" />
									</group>

									<group>
										<field name="warehouse_ids" required="1" 
										    widget="many2many_tags"
											attrs="{'readonly': [('state', '!=', 'new')]}"
											options="{'no_create': True, 'no_create_edit': True , 'no_open': True}" />
										<field name="stock_field" required="1"
											attrs="{'readonly': [('state', '!=', 'new')]}"
											options="{'no_create': True, 'no_create_edit': True , 'no_open': True}"
											domain="[('model_id.model','=','product.product'),('ttype','=','float')]" />
									</group>
								</group>
							</page>

							<page string="Google Shopping Settings">
								<group>
									<group string="Website Informations">
										<field name="gs_website_id" required="1"
											domain="[('company_id', '=', gs_company_id)]"
											attrs="{'readonly': [('state', '!=', 'new')]}"
											options="{'no_create': True, 'no_create_edit': True , 'no_open': True}" />
										<field name="gs_website_domain" required="1"
											attrs="{'readonly': [('state', '!=', 'new')]}" />
										<field name="gs_authorized_redirect_uri" readonly="1"
											force_save="1" required="1" />
									</group>
									<group string="Claim/Verify Website">
										<label for="google_shopping_account_claim_filename" />
										<div class="o_row">
											<field name="google_shopping_account_claim_filename"
												required="1" 
												attrs="{'readonly': [('state', '!=', 'new')]}" />
											<button icon="fa-arrow-right" class="btn-primary"
												name="claim_your_website_with_google" type="object"
												string="Claim/Verify Website" />
										</div>
									</group>
								</group>

								<group string="Shopping API Credentials">
									<field name="gs_merchant_id" required="1"
										attrs="{'readonly': [('state', '!=', 'new')]}" />
									<field name="gs_client_id" password="True" required="1"
										attrs="{'readonly': [('state', '!=', 'new')]}" />
									<field name="gs_client_secret_key" password="True"
										required="1" attrs="{'readonly': [('state', '!=', 'new')]}" />
									<field name="gs_client_auth_code" password="True"
										readonly="1" force_save="1" />
									<field name="gs_client_auth_access_token" password="True"
										readonly="1" force_save="1" />
									<field name="gs_client_auth_refresh_token"
										password="True" readonly="1" force_save="1" />
									<!-- <field name="google_shopping_account_claim_file" required='1' 
										filename="google_shopping_account_claim_filename" /> -->
								</group>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record>

		<!-- Action View Section -->
		<record id="google_shopping_feed_account_action"
			model="ir.actions.act_window">
			<field name="name">Google Shopping Account</field>
			<field name="res_model">google.shopping.feed.account</field>
			<field name="view_id"
				ref="google_shopping_feed_account_tree_view" />
			<field name="help" type="html">
				<div>
					<br />
					<p>
						<b>There is no any Google Shopping Account configured yet.</b>
					</p>

				</div>
			</field>
		</record>

		<!-- Menu Section -->
		<menuitem id="google_shopping_feed_account_menu"
			name="Shopping Account" parent="google_shopping_feed_gcs.google_shopping_feed_config_menu"
			sequence="2" action="google_shopping_feed_account_action" />
	</data>
</odoo>
