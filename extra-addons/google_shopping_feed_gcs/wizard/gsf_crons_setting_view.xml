<?xml version="1.0" encoding="utf-8"?>

<odoo>
	<data>
	
		<!-- Form View Section -->
		<record id="gsf_crons_setting_from_view" model="ir.ui.view">
			<field name="name">Google Shopping Account Crons Setting</field>
			<field name="model">gsf.crons.settings</field>
			<field name="arch" type="xml">
				<form>
					<group string="Export/Update Schedulers">
						<group>
							<field name="gsf_account_id" invisible="1" />
							<field name="is_auto_update_products_in_gsf" />
							<field name="auto_update_products_in_gsf_interval_number" attrs="{'invisible': [('is_auto_update_products_in_gsf', '=', False)], 'required': [('is_auto_update_products_in_gsf', '=', True)]}" />
							<field name="auto_update_products_in_gsf_interval_type" attrs="{'invisible': [('is_auto_update_products_in_gsf', '=', False)], 'required': [('is_auto_update_products_in_gsf', '=', True)]}" />
							<field name="auto_update_products_in_gsf_nextcall" attrs="{'invisible': [('is_auto_update_products_in_gsf', '=', False)], 'required': [('is_auto_update_products_in_gsf', '=', True)]}" />
							<field name="auto_update_products_in_gsf_user_id" attrs="{'invisible': [('is_auto_update_products_in_gsf', '=', False)], 'required': [('is_auto_update_products_in_gsf', '=', True)]}" />
						</group>
						
						<group>
							<field name="is_auto_update_products_inventory_info_in_gsf" />
							<field name="auto_update_products_inventory_info_in_gsf_interval_number" attrs="{'invisible': [('is_auto_update_products_inventory_info_in_gsf', '=', False)], 'required': [('is_auto_update_products_inventory_info_in_gsf', '=', True)]}" />
							<field name="auto_update_products_inventory_info_in_gsf_interval_type" attrs="{'invisible': [('is_auto_update_products_inventory_info_in_gsf', '=', False)], 'required': [('is_auto_update_products_inventory_info_in_gsf', '=', True)]}" />
							<field name="auto_update_products_inventory_info_in_gsf_nextcall" attrs="{'invisible': [('is_auto_update_products_inventory_info_in_gsf', '=', False)], 'required': [('is_auto_update_products_inventory_info_in_gsf', '=', True)]}" />
							<field name="auto_update_products_inventory_info_in_gsf_user_id" attrs="{'invisible': [('is_auto_update_products_inventory_info_in_gsf', '=', False)], 'required': [('is_auto_update_products_inventory_info_in_gsf', '=', True)]}" />	
						</group>
					</group>
					<group string="Import/Sync. Schedulers">
						<group>
							<field name="is_auto_get_products_status_from_gsf" />
							<field name="auto_get_products_status_from_gsf_interval_number" attrs="{'invisible': [('is_auto_get_products_status_from_gsf', '=', False)], 'required': [('is_auto_get_products_status_from_gsf', '=', True)]}" />
							<field name="auto_get_products_status_from_gsf_interval_type" attrs="{'invisible': [('is_auto_get_products_status_from_gsf', '=', False)], 'required': [('is_auto_get_products_status_from_gsf', '=', True)]}" />
							<field name="auto_get_products_status_from_gsf_nextcall" attrs="{'invisible': [('is_auto_get_products_status_from_gsf', '=', False)], 'required': [('is_auto_get_products_status_from_gsf', '=', True)]}" />
							<field name="auto_get_products_status_from_gsf_user_id" attrs="{'invisible': [('is_auto_get_products_status_from_gsf', '=', False)], 'required': [('is_auto_get_products_status_from_gsf', '=', True)]}" />
						</group>
						<group>
							<field name="is_auto_import_products_info_from_gsf" />
							<field name="auto_import_products_info_from_gsf_interval_number" attrs="{'invisible': [('is_auto_import_products_info_from_gsf', '=', False)], 'required': [('is_auto_import_products_info_from_gsf', '=', True)]}" />
							<field name="auto_import_products_info_from_gsf_interval_type" attrs="{'invisible': [('is_auto_import_products_info_from_gsf', '=', False)], 'required': [('is_auto_import_products_info_from_gsf', '=', True)]}" />
							<field name="auto_import_products_info_from_gsf_nextcall" attrs="{'invisible': [('is_auto_import_products_info_from_gsf', '=', False)], 'required': [('is_auto_import_products_info_from_gsf', '=', True)]}" />
							<field name="auto_import_products_info_from_gsf_user_id" attrs="{'invisible': [('is_auto_import_products_info_from_gsf', '=', False)], 'required': [('is_auto_import_products_info_from_gsf', '=', True)]}" />
						</group>
					</group>
					
					<footer>
						<button string="Save Crons Setting" class="oe_highlight" type="object"
							name="action_save_gsf_crons_setting" />
						<button string="Cancel" class="oe_highlight"
							special="cancel" />
					</footer>
				</form>
			</field>
		</record>

	</data>
</odoo>