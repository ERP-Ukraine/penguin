<?xml version="1.0" encoding="utf-8"?>

<odoo>
	<data>
		<!-- Odoo <=> Google Shopping Operations -->
		<!-- Form View Section -->
		<record
			id="google_shopping_odoo_import_export_operations_form_view"
			model="ir.ui.view">
			<field name="name">google.shopping.odoo.import.export.operations.form
			</field>
			<field name="model">google.shopping.process.import.export</field>
			<field name="arch" type="xml">
				<form>
					<sheet>
						<group>
							<group>
								<field name="gsf_account_id"
									domain="[('state','=','confirmed')]"
									options="{'no_create':True, 'no_create_edit': True, 'no_open': True}" />
								<field name='instance_ids' widget="many2many_tags"
									domain="[('state','=','confirmed'), ('gs_account_id', '=', gsf_account_id)]"
									attrs="{'invisible':[('gsf_account_id','=',False)]}"
									options="{'no_create':True, 'no_create_edit': True}" />
									
								<field name="gsf_import_export_type" attrs="{'invisible':[('instance_ids','=',[])]}" required="1"/>
								<field name="gsf_sub_operation_type1" attrs="{'invisible':['|', '|', ('gsf_import_export_type','not in',['import_sync']), ('gsf_import_export_type','=',False), ('instance_ids', '=', [])], 'required': [('gsf_import_export_type', 'in', 'import_sync')]}" />
								<field name="gsf_sub_operation_type2" attrs="{'invisible':['|', '|', ('gsf_import_export_type','not in',['export_update']), ('gsf_import_export_type','=',False), ('instance_ids', '=', [])], 'required': [('gsf_import_export_type', 'in', 'export_update')]}" />
							</group>
							<group>
							</group>
						</group>

						<footer>
							<button string="Execute" class="oe_highlight"
								type="object" name="action_execute" />
							<button string="Cancel" class="oe_highlight"
								special="cancel" />
						</footer>
					</sheet>
				</form>
			</field>
		</record>

		<!-- Action View Section -->
		<record
			id="google_shopping_odoo_import_export_operations_action"
			model="ir.actions.act_window">
			<field name="name">Google Shopping Operations</field>
			<field name="res_model">google.shopping.process.import.export</field>
			<field name="view_mode">form</field>
			<field name="target">new</field>
		</record>

		<record
			id="google_shopping_odoo_import_export_operations_action_from_view"
			model="ir.actions.act_window.view">
			<field name="sequence" eval="1" />
			<field name="view_mode">form</field>
			<field name="view_id"
				ref="google_shopping_odoo_import_export_operations_form_view" />
			<field name="act_window_id"
				ref="google_shopping_odoo_import_export_operations_action" />
		</record>

		<!-- Instance Menu Section -->
		<menuitem
			id="google_shopping_odoo_import_export_operations_menu"
			name="Google Shopping Operations"
			parent="google_shopping_feed_gcs.google_shopping_operation_menu" sequence="1"
			action="google_shopping_odoo_import_export_operations_action" />
	</data>
</odoo>