<odoo>
    <record id="foreg_webhook_view_form" model="ir.ui.view">
        <field name="name">foreg.webhook.view.form</field>
        <field name="model">foreg.webhook</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field
                                name="name"
                                placeholder="e.g. Update Customer"
                            /></h1>
                    </div>
                    <notebook>
                        <page string="General" name="general">
                            <group>
                                <group>
                                    <field name="description" />
                                    <field name="trigger" />
                                    <field
                                        name="model_id"
                                        invisible="trigger == 'on_webhook'"
                                    />
                                    <field name="url" widget="CopyClipboardURL" />
                                </group>
                                <group>
                                    <field name="active" />
                                    <field name="max_retries" />
                                    <field name="retry_interval" />
                                </group>
                            </group>
                        </page>
                        <page
                            string="Code"
                            name="code"
                            invisible="trigger != 'on_webhook'"
                        >
                            <group>
                                <field name="template_id" />
                                <field
                                    name="code"
                                    widget="ace"
                                    options="{'mode': 'python'}"
                                />
                            </group>
                        </page>
                        <page
                            string="Technical"
                            name="technical"
                            groups="base.group_system"
                        >
                            <group>
                                <field name="webhook_uuid" force_save="1" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="foreg_webhook_view_tree" model="ir.ui.view">
        <field name="name">foreg.webhook.view.list</field>
        <field name="model">foreg.webhook</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="description" />
                <field name="trigger" />
                <field name="model_id" />
            </list>
        </field>
    </record>
    <record id="foreg_webhook_view_search" model="ir.ui.view">
        <field name="name">foreg.webhook.view.search</field>
        <field name="model">foreg.webhook</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="description" />
                <field name="trigger" />
                <field name="model_id" />
            </search>
        </field>
    </record>
    <record id="foreg_webhook_action" model="ir.actions.act_window">
        <field name="name">4EG Webhooks</field>
        <field name="res_model">foreg.webhook</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
