<odoo>
    <record id="foreg_webhook_code_template_view_tree" model="ir.ui.view">
        <field name="name">foreg.webhook.code.template.view.list</field>
        <field name="model">foreg.webhook.code.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="description" />
            </list>
        </field>
    </record>
    <record id="foreg_webhook_code_template_view_form" model="ir.ui.view">
        <field name="name">foreg.webhook.code.template.view.form</field>
        <field name="model">foreg.webhook.code.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="description" />
                            <field name="active" />
                        </group>
                        <field name="code" widget="ace" options="{'mode': 'python'}" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="foreg_webhook_code_template_view_search" model="ir.ui.view">
        <field name="name">foreg.webhook.code.template.view.search</field>
        <field name="model">foreg.webhook.code.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="description" />
                <filter
                    name="all"
                    string="All"
                    domain="['|', ('active', '=', False), ('active', '=', True)]"
                />
                <filter
                    name="archived"
                    string="Archived"
                    domain="[('active', '=', False)]"
                />
            </search>
        </field>
    </record>
    <record id="foreg_webhook_code_template_action" model="ir.actions.act_window">
        <field name="name">4EG Webhook Code Templates</field>
        <field name="res_model">foreg.webhook.code.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
