<odoo>
    <!-- Form View -->
    <record id="foreg_data_import_export_view_form" model="ir.ui.view">
        <field name="name">foreg.data.import.export.view.form</field>
        <field name="model">foreg.data.import.export</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_export_data"
                        string="Export Data"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        name="action_import_data"
                        string="Import Data"
                        type="object"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field
                                name="name"
                                placeholder="e.g. Export Partners with Contacts"
                            />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model" required="1" />
                            <field name="export_sensitive_information" />
                            <field
                                name="data_file"
                                filename="data_filename"
                                widget="binary"
                            />
                            <field name="data_filename" invisible="1" />
                        </group>
                    </group>
                    <group string="Summary" invisible="summary == False">
                        <field name="summary" nolabel="1" colspan="4" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="foreg_data_import_export_view_tree" model="ir.ui.view">
        <field name="name">foreg.data.import.export.view.tree</field>
        <field name="model">foreg.data.import.export</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="data_filename" />
                <field name="create_date" />
                <field name="create_uid" />
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="foreg_data_import_export_view_search" model="ir.ui.view">
        <field name="name">foreg.data.import.export.view.search</field>
        <field name="model">foreg.data.import.export</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="data_filename" />
                <group expand="0" string="Group By">
                    <filter
                        name="group_by_create_date"
                        string="Creation Date"
                        domain="[]"
                        context="{'group_by': 'create_date'}"
                    />
                    <filter
                        name="group_by_create_uid"
                        string="Created By"
                        domain="[]"
                        context="{'group_by': 'create_uid'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="foreg_data_import_export_action" model="ir.actions.act_window">
        <field name="name">Import/Export Data</field>
        <field name="res_model">foreg.data.import.export</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No import/export records found
            </p>
            <p>
                This module provides API functions for importing and exporting data.
                Records will be displayed here when programmatically created by other modules.
            </p>
        </field>
    </record>


</odoo>
