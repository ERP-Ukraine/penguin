<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="view_order_form_sale_arnol_switch" model="ir.ui.view">
        <field name="name">sale.order.form.sale.arnold</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group[@name='partner_details']//field[@name='partner_id']" position="after">
                <field name="hide_manual_arnold_sale" invisible="1"/>
                <field name="manual_sale_for_arnold" attrs="{'invisible': [('hide_manual_arnold_sale', '=', True)]}"/>
            </xpath>

        </field>
    </record>

</odoo>
