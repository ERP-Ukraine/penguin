<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record model="ir.actions.server" id="action_transfer_customer_data">
            <field name="name">Penguin: Customer import</field>
            <field name="model_id" ref="model_db_data_transfer"/>
            <field name="binding_model_id" ref="base.model_ir_actions_server" />
            <field name="state">code</field>
            <field name="code">
model.transfer_models_data([
    'res.company',
    'res.users',
    'res.partner',
])
            </field>
        </record>

        <record model="ir.actions.server" id="action_transfer_product_data">
            <field name="name">Penguin: Product import</field>
            <field name="model_id" ref="model_db_data_transfer"/>
            <field name="binding_model_id" ref="base.model_ir_actions_server" />
            <field name="state">code</field>
            <field name="code">
model.transfer_models_data([
    'product.washing.instruction',
    'product.material',
    'product.feature',
    'product.public.category',
    'product.attribute',
    'product.attribute.value',
    'product.template',
    'product.product'
])
            </field>
        </record>

        <record model="ir.actions.server" id="action_transfer_sale_order_data">
            <field name="name">Penguin: Sale Order import</field>
            <field name="model_id" ref="model_db_data_transfer"/>
            <field name="binding_model_id" ref="base.model_ir_actions_server" />
            <field name="state">code</field>
            <field name="code">
model.transfer_models_data([
    'sale.order',
])
            </field>
        </record>

        <record model="ir.actions.server" id="action_transfer_customer_fiscal_position_data">
            <field name="name">Penguin: Customer Fiscal Position import</field>
            <field name="model_id" ref="model_db_data_transfer"/>
            <field name="binding_model_id" ref="base.model_ir_actions_server" />
            <field name="state">code</field>
            <field name="code">
model.transfer_models_data([
    'account.fiscal.position',
])
            </field>
        </record>
    </data>
</odoo>