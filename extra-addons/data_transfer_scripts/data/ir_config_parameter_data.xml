<?xml version="1.0" ?>
<odoo>
    <data noupdate="1">
        <record id="old_db_name" model="ir.config_parameter">
            <field name="key">database.old.dbname</field>
            <field name="value">penguin</field>
        </record>

        <record id="old_db_port" model="ir.config_parameter">
            <field name="key">database.old.port</field>
            <field name="value">5432</field>
        </record>

        <record id="old_db_host" model="ir.config_parameter">
            <field name="key">database.old.host</field>
            <field name="value">localhost</field>
        </record>

        <record id="old_db_user" model="ir.config_parameter">
            <field name="key">database.old.user</field>
            <field name="value">odoo</field>
        </record>

        <record id="old_db_password" model="ir.config_parameter">
            <field name="key">database.old.password</field>
            <field name="value">odoo</field>
        </record>

    </data>
</odoo>
