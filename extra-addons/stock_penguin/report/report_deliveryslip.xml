<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<template id="penguin_external_layout_standard" inherit_id="web.external_layout_standard">
    <xpath expr="//div[@name='company_address']" position="replace">
        <div class="col-6" name="company_address">
            <t t-if="custom_company_address">
                <div>
                    <strong t-field="company.partner_id.name"/>
                </div>
                <div t-esc="custom_company_address"
                        t-options='{"widget": "contact", "fields": ["address"], "no_marker": true}'/>
            </t>
            <t t-else="">
                <div t-field="company.partner_id"
                    t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'
                />
            </t>
        </div>
    </xpath>
</template>

<template id="penguin_report_delivery_document" inherit_id="stock.report_delivery_document">
    <xpath expr="//t[@t-call='web.external_layout']" position="before">
        <t t-set="custom_company_address" t-value="o.picking_type_id.warehouse_id.partner_id"/>
    </xpath>

    <xpath expr="//div[@name='div_outgoing_address']/div/span" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>

    <xpath expr="//div[@name='div_outgoing_address']/div[last()]/span" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>

    <!-- remove phone field from widget -->
    <xpath expr="//div[@name='div_outgoing_address']/div[1]/div" position="attributes">
        <attribute name="t-options">
            {'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True, 'phone_icons': False}
        </attribute>
    </xpath>

    <xpath expr="//div[@name='div_outgoing_address']/div[last()]/div" position="attributes">
        <attribute name="t-options">
            {'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True, 'phone_icons': False}
        </attribute>
    </xpath>

    <xpath expr="//div[@name='div_outgoing_address']" position="attributes">
        <attribute name="class" add="pb-4" separator=" "/>
    </xpath>

    <xpath expr="//div[@t-if='show_partner']/div" position="attributes">
        <attribute name="t-options">
            {'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True, 'phone_icons': False}
        </attribute>
    </xpath>

    <xpath expr="//t[@t-set='information_block']/div" position="attributes">
        <attribute name="class" add="mb-2" separator=" "/>
    </xpath>

    <xpath expr="//div[@name='div_origin']" position="attributes">
        <attribute name="class" add="col-2" remove="col-auto" separator=" "/>
    </xpath>

    <xpath expr="//div[@name='div_sched_date']" position="attributes">
        <attribute name="class" add="col-2" remove="col-auto" separator=" "/>
    </xpath>

    <xpath expr="//div[@name='div_origin']/parent::div" position="attributes">
        <attribute name="class" add="mb-3" remove="mb32" separator=" "/>
    </xpath>

    <xpath expr="//th[@name='th_sm_ordered']" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>

    <xpath expr="//span[@t-field='move.product_uom_qty']/parent::td" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>

    <xpath expr="//th[@name='th_sml_qty_ordered']" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>

    <xpath expr="//span[@t-field='move.product_uom_qty']/parent::td" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>

    <xpath expr="//tr[@t-foreach='lines']/td[3]/span[@t-field='move.product_uom']" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>

    <xpath expr="//div[hasclass('page')]/div[@t-else='']" position="after">
        <div t-if="o.backorder_ids and backorders" name="as_soon_available">
            <p>All items could not be shipped, the rest will be shipped as soon as they become available</p>
        </div>
    </xpath>

    <xpath expr="//div[hasclass('page')]/div[@t-else='']" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>
</template>

<template id="stock_report_delivery_has_serial_move_line" inherit_id="stock.stock_report_delivery_has_serial_move_line">
    <xpath expr="//span[@t-field='move_line.product_uom_id']" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>
</template>

<template id="stock_report_delivery_aggregated_move_lines" inherit_id="stock.stock_report_delivery_aggregated_move_lines">
    <xpath expr="//td[@name='move_line_aggregated_qty_ordered']" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>
    <xpath expr="//td[@name='move_line_aggregated_quantity']/t/span[2]" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>
    <xpath expr="//td[@name='move_line_aggregated_quantity']/t/span[3]" position="attributes">
        <attribute name="class" add="d-none" separator=" "/>
    </xpath>
</template>
</odoo>
