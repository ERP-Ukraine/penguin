<odoo>
    <record id="view_wallee_payment_provider_log_search" model="ir.ui.view">
        <field name="name">wallee.payment.provider.log.search.view</field>
        <field name="model">wallee.payment.provider.log</field>
        <field name="arch" type="xml">
            <search string="Wallee Payment Provider Logs">
                <field name="name"/>
                <field name="detail"/>
                <field name="create_date"/>
            </search>
        </field>
    </record>
    <record id="view_wallee_payment_provider_log_tree" model="ir.ui.view">
        <field name="name">wallee.payment.provider.log.tree.view</field>
        <field name="model">wallee.payment.provider.log</field>
        <field name="arch" type="xml">
            <list string="Wallee Payment Provider Logs" create="false" edit="false" delete="false">
                <field name="create_date" readonly="1"/>
                <field name="detail" readonly="1"/>
                <field name="provider_id" readonly="1"/>
                <field name="name" readonly="1"/>
            </list>
        </field>
    </record>
    <record id="view_wallee_payment_provider_log_form" model="ir.ui.view">
        <field name="name">wallee.payment.provider.log.form.view</field>
        <field name="model">wallee.payment.provider.log</field>
        <field name="arch" type="xml">
            <form string="Wallee Payment Provider Logs" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="detail" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="provider_id" readonly="1" options="{'no_open': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="API Response" name="wallee_api_response">
                            <group>
                                <field name="response_data" readonly="1" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_wallee_payment_provider_log" model="ir.actions.act_window">
        <field name="name">Wallee Payment Provider Logs</field>
        <field name="res_model">wallee.payment.provider.log</field>
        <field name='view_mode'>list,form</field>
        <field name="domain">[('provider_id', '=', active_id)]</field>
        <field name="view_id" ref="view_wallee_payment_provider_log_tree"/>
        <field name="search_view_id" ref="view_wallee_payment_provider_log_search"/>
    </record>
</odoo>
