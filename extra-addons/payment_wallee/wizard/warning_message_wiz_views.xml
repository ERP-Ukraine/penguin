<odoo>
    <record id="view_warning_message_wizard" model="ir.ui.view">
        <field name="name">warning.message.wizard.form</field>
        <field name="model">warning.message.wizard</field>
        <field name="arch" type="xml">
            <form string="Warning">
                <div>
                    <field name="message" style="text-align: center;color: red;font-size: 125%;"/>
                </div>
                <footer>
                    <button string="OK" special="cancel" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>