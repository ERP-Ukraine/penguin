<templates xml:space="preserve">
    <t t-name="payment_wallee.WalleeiFrameDialog">
        <Dialog size="'md'" title="props.title" modalRef="modalRef">
            <p t-out="props.body" class="text-prewrap"/>
            <t t-set-slot="footer">
                <button class="btn" t-att-class="props.confirmClass" t-on-click="_confirm" t-esc="props.confirmLabel"
                        t-att-id="props.confirmId"/>
                <button t-if="props.cancel" class="btn btn-secondary btn-close-modal" t-on-click="_cancel"
                        t-esc="props.cancelLabel" t-att-id="props.cancelId"/>
            </t>
        </Dialog>
    </t>
</templates>
