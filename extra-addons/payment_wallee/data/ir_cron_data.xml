<odoo>
    <data noupdate="1">
        <!-- Cron to update payment transaction state-->
        <record model="ir.cron" id="cron_update_lastest_wallee_state">
            <field name='name'>Wallee: Update wallee state of transaction</field>
            <field name='interval_number'>3</field>
            <field name='interval_type'>hours</field>
            <field name="active">True</field>
            <field name="model_id" ref="payment_wallee.model_payment_provider"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_wallee_state()</field>
        </record>
        <!--  Cron to update payment transaction state -->
        <record model="ir.cron" id="cron_update_lastest_wallee_refund_state">
            <field name="name">Wallee: Update wallee state of Refund</field>
            <field name="interval_number">3</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="model_id" ref="payment_wallee.model_payment_provider"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_wallee_refund_state()</field>
        </record>
        <!--  Cron to update payment methods from wallee back office -->
        <record model="ir.cron" id="cron_synchronize_payment_method_values_from_wallee">
            <field name='name'>Wallee: Synchronize Payment Method values from Wallee</field>
            <field name='interval_number'>10</field>
            <field name='interval_type'>minutes</field>
            <field name="active">True</field>
            <field name="model_id" ref="payment.model_payment_provider"/>
            <field name="state">code</field>
            <field name="code">model.cron_synchronize_payment_method_values()</field>
        </record>
    </data>
</odoo>