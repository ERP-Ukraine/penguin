            <div class="row">
              <div class="col-lg-12 pb0">
                <p class="lead">
                  <font style="font-size: 36px;">Penguin products are durable. We believe in durability as a key driver for sustainability. </font>
                  <br/>
                </p>
                <p>
                  <span style="font-weight: normal;"> </span>
                </p>
                <p class="lead" style="text-align: left;">Find out more about our Penguin Care program!</p>
              </div>
              <div class="s_btn text-right offset-lg-4 col-lg-8 pt0 pb0" data-name="Button" style="text-align: right; ">
                <a href="/penguincare" class="btn btn-primary btn-lg" data-original-title="" title="" aria-describedby="tooltip635247">Penguin Care&amp;nbsp;<i class="fa fa-1x fa-arrow-circle-right fa-fw ml-1" data-original-title="" title="" aria-describedby="tooltip717378"/></a>
              </div>
            </div>
          </div>
        </section>
