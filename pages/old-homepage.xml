<t name="Homepage" t-name="website.homepage1">
    <t t-call="website.layout">
      <t t-set="pageName" t-value="'homepage'"/>
      <div id="wrap" class="oe_structure oe_empty">
        <section class="s_banner parallax s_parallax_is_fixed s_parallax_no_overflow_hidden pb256 pt144" data-scroll-background-ratio="1" data-name="Banner" style="background-image: none;">
